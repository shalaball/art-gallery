{
  "name": "shala-gallery-admin",
  "version": "1.0.0",
  "description": "Local admin UI for Shala Gallery",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-packager . 'Art Gallery Admin' --platform=darwin --arch=arm64 --out=dist --overwrite --ignore=dist --ignore=uploads_tmp --ignore=server.log --ignore='.env'"
  },
  "dependencies": {
    "express": "^4.18.2",
    "heic-convert": "^2.1.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-packager": "^17.1.2"
  }
}
