#!/bin/bash
# Starts the Shala Gallery admin server via Terminal (which has Documents access).

NODE=/usr/local/bin/node
NPM=/usr/local/bin/npm
if [ ! -f "$NODE" ]; then NODE=/opt/homebrew/bin/node; fi
if [ ! -f "$NPM" ]; then NPM=/opt/homebrew/bin/npm; fi

GALLERY_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
ADMIN_DIR="$GALLERY_DIR/admin"
LOG="$ADMIN_DIR/server.log"

# If already running, just open browser
if curl -s http://localhost:3000 > /dev/null 2>&1; then
  open http://localhost:3000
  exit 0
fi

# Open Terminal (has Documents access), start node in background, then force-close the window.
osascript << OSASCRIPT
tell application "Terminal"
    set t to do script "cd '$ADMIN_DIR' && ([ -d node_modules ] || '$NPM' install >> '$LOG' 2>&1) && nohup '$NODE' server.js >> '$LOG' 2>&1 & disown; exit 0"
    delay 2
    close (window of t)
end tell
OSASCRIPT

# Wait up to 30s for server to be ready
for i in $(seq 1 60); do
  sleep 0.5
  if curl -s http://localhost:3000 > /dev/null 2>&1; then
    break
  fi
done

open http://localhost:3000
